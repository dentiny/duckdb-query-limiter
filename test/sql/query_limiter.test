# name: test/sql/query_limiter.test
# description: test query_limiter extension
# group: [sql]

load __TEST_DIR__/query_limiter_persistent.db

require query_limiter

statement ok
CREATE TABLE limiter_small AS SELECT i FROM range(5) tbl(i);

statement ok
CREATE TABLE limiter_large AS SELECT i FROM range(100) tbl(i);

statement ok
CHECKPOINT;

# TODO(hjiang): there's a stats optimization bug in DuckDB core, that committed but unpersisted row group doesn't prune correctly.
restart

statement ok
LOAD query_limiter;

# The default budget is idx_t max, so queries are effectively unrestricted
# unless the setting is configured.
query I
SELECT count(*) FROM limiter_large;
----
100

statement ok
SET max_rows_to_scan = 10;

# A persisted table scan below the limit is allowed.
query I
SELECT count(*) FROM limiter_small;
----
5

# COUNT(*) on a checkpointed table can be answered from metadata and does not scan rows.
query I
SELECT count(*) FROM limiter_large;
----
100

# A persisted table scan above the limit is rejected using table metadata before physical execution.
statement error
SELECT sum(i) FROM limiter_large;
----
Query rejected by max_rows_to_scan

# LIMIT constrains output rows, not estimated input rows to scan.
statement error
SELECT * FROM limiter_large LIMIT 1;
----
Query rejected by max_rows_to_scan

statement ok
SET max_rows_to_scan = 150;

# A high enough budget allows the same large scan.
query I
SELECT count(*) FROM limiter_large;
----
100

statement ok
SET max_rows_to_scan = 60;

# Scan estimates are summed across multiple table scans.
statement error
SELECT count(*) FROM limiter_small, limiter_large WHERE limiter_small.i = limiter_large.i;
----
Query rejected by max_rows_to_scan

statement ok
RESET max_rows_to_scan;

# Resetting returns to the default max budget.
query I
SELECT count(*) FROM limiter_large;
----
100
